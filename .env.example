# 用法：在 Codespace 终端里复制本文件为 .env，填入第三方令牌。
#       .env 已被 .gitignore 忽略，不会提交到仓库。
# 新开的终端会自动 source 这个 .env（见 devcontainer.json），让 claude 走第三方 API。

# 第三方中转地址（与 devcontainer.json 里保持一致）
ANTHROPIC_BASE_URL=https://cc.freemodel.dev

# 第三方令牌：从你本机 ~/.claude/settings.json 里复制，形如 fe_oa_...
ANTHROPIC_AUTH_TOKEN=在这里填入你的第三方令牌

# 默认 Opus 模型名
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-8
